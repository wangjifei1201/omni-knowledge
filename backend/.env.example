# Application
APP_NAME=omni-knowledge
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-change-in-production

# Database Type: "postgresql" or "mysql"
DB_TYPE=mysql

# PostgreSQL (used when DB_TYPE=postgresql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=omni_knowledge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MySQL (used when DB_TYPE=mysql)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=omni_knowledge
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_CHARSET=utf8mb4

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# FAISS Vector Store (Local)
FAISS_INDEX_PATH=./data/faiss_index

# Local File Storage (replaces MinIO)
LOCAL_STORAGE_PATH=./data/storage

# LLM Service
LLM_API_BASE=http://localhost:8080/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL_NAME=qwen2.5-72b-instruct

# Embedding Service
EMBEDDING_API_BASE=http://localhost:8081/v1
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_MODEL_NAME=bge-large-zh-v1.5
EMBEDDING_DIMENSION=1024

# Reranker Service
RERANKER_API_BASE=http://localhost:8082/v1
RERANKER_MODEL_NAME=bge-reranker-large

# Default Admin Account (created on first startup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
